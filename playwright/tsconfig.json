{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "../test-results/.tsc",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@support/*": ["./support/*"],
      "@factories/*": ["./support/factories/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}

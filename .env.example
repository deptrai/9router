# 9Router environment contract
# This file reflects actual runtime usage in the current codebase.

# Required
JWT_SECRET=change-me-to-a-long-random-secret
INITIAL_PASSWORD=change-me
DATA_DIR=/var/lib/9router

# Recommended runtime variables
PORT=20128
NODE_ENV=production

# Recommended security and ops variables
API_KEY_SECRET=endpoint-proxy-api-key-secret
MACHINE_ID_SALT=endpoint-proxy-salt
ENABLE_REQUEST_LOGS=false
OBSERVABILITY_ENABLED=true
AUTH_COOKIE_SECURE=false
REQUIRE_API_KEY=false

# Cloud sync variables
# Must point to this running instance so internal sync jobs can call /api/sync/cloud.
# Server-side preferred variables:
BASE_URL=http://localhost:20128
CLOUD_URL=https://9router.com
# Backward-compatible/public variables:
NEXT_PUBLIC_BASE_URL=http://localhost:20128
NEXT_PUBLIC_CLOUD_URL=https://9router.com

# Optional outbound proxy variables for upstream provider calls
# Lowercase variants are also supported: http_proxy, https_proxy, all_proxy, no_proxy
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1

# Email verification (Story 2.6 — MVP-2, optional)
# Để trống → email verify skip êm, luồng đăng ký/login không bị ảnh hưởng (fail-soft).
# Ưu tiên: MAILPIT_URL (local dev) > RESEND_API_KEY+EMAIL_FROM (production)
# MAILPIT_URL=http://localhost:8025
# RESEND_API_KEY=re_your_api_key_here
# EMAIL_FROM=9Router <noreply@yourdomain.com>

# Currently unused by application runtime (kept as reference)
# INSTANCE_NAME=9router

# Crypto Payment — Story 2.8 (MVP-2, Epic D)
# NOWPayments gateway for stablecoin USDT/USDC topup.
# Để trống → POST /api/payments/create trả 503 (crypto payment unavailable).
# NOWPAYMENTS_API_KEY=your_nowpayments_api_key
# NOWPAYMENTS_IPN_SECRET=your_ipn_webhook_secret
CRYPTO_PAYMENT_ENABLED=true
CRYPTO_BONUS_PERCENT=15

# Crypto payment (Story 2.8 — NOWPayments, Story 2.9 — provider abstraction + Bitcart)
# CRYPTO_PAYMENT_PROVIDER=auto   # auto | nowpayments | bitcart
# BITCART_BASE_URL=http://localhost:8000
# BITCART_API_KEY=
# BITCART_STORE_ID=
# BITCART_WEBHOOK_SECRET=

# Telegram Store — Credential Encryption (Story 2.27, NFR8)
# AES-256-GCM key for credential payloads at rest. Required when using kind=credential products.
# Generate: openssl rand -hex 32
# STORE_ENC_KEY=your_64_char_hex_key_here

# Cloudflare Turnstile (captcha on /register). Leave empty to disable captcha (local dev).
# Create a widget: dash.cloudflare.com > Turnstile > Add site (or via API).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
